#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real script directory
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
COMPOSE_WEB_PORTS_FILE="$SCRIPT_DIR/docker-compose.web-ports.yml"
PORTS_FILE="$SCRIPT_DIR/ports.conf"

# macOS Docker Desktop puts binaries here
if [[ -d /Applications/Docker.app/Contents/Resources/bin ]]; then
    export PATH="/Applications/Docker.app/Contents/Resources/bin:$PATH"
fi

# Look up a static port for an instance from ports.conf
# Usage: get_port <instance> [dashboard|terminal]
get_port() {
    local instance="$1"
    local type="${2:-dashboard}"
    if [[ -f "$PORTS_FILE" ]]; then
        local port
        port=$(grep -E "^${instance}\.${type}=" "$PORTS_FILE" 2>/dev/null | cut -d= -f2 | tr -d ' ')
        if [[ -n "$port" ]]; then
            echo "$port"
            return
        fi
    fi
    echo "0"  # auto-assign
}

usage() {
    cat <<'EOF'
gt-docker — manage isolated Gas Town Docker instances

Usage:
  gt-docker up <instance>            Create and start an instance
  gt-docker down <instance>          Stop and remove an instance (keeps volumes)
  gt-docker destroy <instance>       Stop, remove, AND delete volumes
  gt-docker mayor <instance>         Attach to the Mayor tmux session
  gt-docker shell <instance>         Open a shell in the container
  gt-docker exec <instance> <cmd..>  Run a command in the container
  gt-docker status <instance> --json  Unified JSON snapshot of instance state
  gt-docker list                     List running gastown containers
  gt-docker logs <instance>          Tail container logs

  gt-docker formulas list            List custom formulas
  gt-docker formulas add <file>      Add a formula to the collection
  gt-docker formulas sync <instance> Push formulas to a running instance
  gt-docker formulas sync --all      Push to all running instances

  gt-docker settings sync <instance> Push plugin settings to a running instance
  gt-docker settings sync --all      Push to all running instances
  gt-docker settings show            Show disabled plugins list

  gt-docker costs <instance> [flags] Show costs (pass-through to gt costs)
  gt-docker costs export <instance>  Export cost ledger to host for trending
  gt-docker tokens <instance> [flags] Show token usage from live sessions

  gt-docker tier <instance> [tier]   Get or set cost tier (standard/economy/budget)
  gt-docker tier --all [tier]        Get or set tier for all running instances

Environment:
  GIT_USER       Git user.name  (default: TestUser)
  GIT_EMAIL      Git user.email (default: test@example.com)
  GT_COST_TIER   Cost tier for new instances (default: budget)
  DASHBOARD_PORT Host port for dashboard (default: auto-assigned)
  WEB_PORTS      Host-to-container web port range (default: 3000-3050:3000-3050)

Cost Tiers:
  standard       All roles use Opus (highest quality, highest cost)
  economy        Patrol roles use Sonnet/Haiku, workers use Opus
  budget         Patrol roles use Haiku, workers use Sonnet (default)

Examples:
  gt-docker up alpha
  gt-docker up bravo
  gt-docker mayor alpha              # attach to alpha's Mayor
  gt-docker exec bravo gt agents     # check agents in bravo
  gt-docker status alpha --json       # JSON snapshot of alpha's state
  gt-docker list                     # see all running instances
  gt-docker tier alpha budget        # switch alpha to budget tier
  gt-docker settings sync --all      # push plugin settings everywhere
  gt-docker destroy alpha            # tear down alpha completely
EOF
    exit 1
}

container_name() {
    echo "gastown-$1"
}

compose_env() {
    local instance="$1"
    export GT_INSTANCE="$instance"
    export COMPOSE_PROJECT_NAME="gt-$instance"
}

require_running() {
    local cname
    cname="$(container_name "$1")"
    if ! docker inspect --format='{{.State.Running}}' "$cname" 2>/dev/null | grep -q true; then
        echo "Error: instance '$1' is not running (container: $cname)" >&2
        echo "Start it with: gt-docker up $1" >&2
        exit 1
    fi
}

compose_files() {
    local args=(-f "$COMPOSE_FILE")
    if [[ -n "${WEB_PORTS:-}" ]]; then
        args+=(-f "$COMPOSE_WEB_PORTS_FILE")
    fi
    echo "${args[@]}"
}

cmd_up() {
    local instance="$1"
    compose_env "$instance"
    export GIT_USER="${GIT_USER:-TestUser}"
    export GIT_EMAIL="${GIT_EMAIL:-test@example.com}"
    export DASHBOARD_PORT="${DASHBOARD_PORT:-$(get_port "$instance" dashboard)}"
    export TERMINAL_PORT="${TERMINAL_PORT:-$(get_port "$instance" terminal)}"
    local webstart
    webstart="$(get_port "$instance" webstart)"
    if [[ "$webstart" != "0" ]]; then
        local webend=$((webstart + 50))
        export WEB_PORTS="${WEB_PORTS:-${webstart}-${webend}:3000-3050}"
    elif [[ -n "${WEB_PORTS:-}" ]]; then
        export WEB_PORTS
    fi
    export GT_COST_TIER="${GT_COST_TIER:-budget}"
    echo "Starting gastown instance '$instance' (cost tier: $GT_COST_TIER)..."
    docker compose $(compose_files) up -d --build
    echo ""
    echo "Instance '$instance' is running."
    echo "  Container:  $(container_name "$instance")"
    echo "  Cost tier:  $GT_COST_TIER"
    if [[ "$DASHBOARD_PORT" != "0" ]]; then
        echo "  Dashboard:  http://${instance}.town"
    fi
    if [[ "$TERMINAL_PORT" != "0" ]]; then
        echo "  Terminal:   http://terminal.${instance}.town"
    fi
    if [[ -n "${WEB_PORTS:-}" ]]; then
        echo "  Web ports:  ${WEB_PORTS%:*} → container 3000-3050"
    fi
    echo ""
    echo "Services (Dolt, Daemon, Deacon, Mayor, Dashboard, Terminal)"
    echo "start automatically inside the container."
    echo ""
    echo "First time? Authenticate Claude:"
    echo "  gt-docker shell $instance"
    echo "  claude login"
    echo ""
    echo "Attach to Mayor:"
    echo "  gt-docker mayor $instance"
}

graceful_shutdown() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"

    if ! docker inspect --format='{{.State.Running}}' "$cname" 2>/dev/null | grep -q true; then
        return
    fi

    # 1. Save Mayor context via handoff mail (persists in /gt Dolt DB)
    echo "  Saving Mayor context for next session..."
    docker exec --user agent "$cname" \
        gt handoff --auto --reason shutdown --no-git-check \
        -s "HANDOFF: gt-docker down" 2>/dev/null || true

    # 2. Record costs for all active sessions before they're killed
    echo "  Recording session costs..."
    docker exec --user agent "$cname" sh -c '
        for sess in $(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^gt-"); do
            GT_SESSION="$sess" gt costs record --session "$sess" 2>/dev/null || true
        done
    ' 2>/dev/null || true

    # 3. Graceful Gastown shutdown (stops agents, dolt, daemon)
    echo "  Stopping Gas Town services..."
    docker exec --user agent "$cname" gt down --all 2>/dev/null || true
}

cmd_down() {
    local instance="$1"
    compose_env "$instance"
    echo "Stopping instance '$instance'..."
    graceful_shutdown "$instance"
    docker compose $(compose_files) down
}

cmd_destroy() {
    local instance="$1"
    compose_env "$instance"
    echo "Destroying instance '$instance' (including volumes)..."
    graceful_shutdown "$instance"
    docker compose $(compose_files) down -v
}

cmd_mayor() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"

    # Check if the mayor tmux session exists
    if docker exec --user agent "$cname" tmux has-session -t hq-mayor 2>/dev/null; then
        echo "Attaching to Mayor in instance '$instance'..."
        docker exec -it --user agent "$cname" tmux attach-session -t hq-mayor
    else
        # No mayor session yet — start one via gt mayor attach
        echo "No Mayor session found in '$instance'. Starting one..."
        docker exec -it --user agent "$cname" /app/gastown/gt mayor attach
    fi
}

cmd_shell() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    docker exec -it --user agent "$cname" zsh
}

cmd_exec_cmd() {
    local instance="$1"
    shift
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    if [[ -t 0 ]]; then
        docker exec -it --user agent "$cname" "$@"
    else
        docker exec --user agent "$cname" "$@"
    fi
}

cmd_list() {
    echo "Running gastown instances:"
    echo ""
    docker ps --filter "name=gastown-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
}

cmd_logs() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    docker logs -f "$cname"
}

cmd_status() {
    local instance="$1"
    shift
    local json_flag=""
    for arg in "$@"; do
        case "$arg" in
            --json) json_flag=true ;;
        esac
    done

    if [[ -z "$json_flag" ]]; then
        echo "Usage: gt-docker status <instance> --json" >&2
        exit 1
    fi

    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"

    # Single docker exec: gather all data inside the container, assemble via jq
    docker exec --user agent "$cname" sh -c '
        # 1. Polecats
        polecats_json=$(gt polecat list --all --json 2>/dev/null || echo "[]")

        # 2. Convoys
        convoys_json=$(gt convoy list --json 2>/dev/null || echo "[]")

        # 3. Open beads by priority
        beads_json=$(bd count 2>/dev/null || echo "null")
        if [ "$beads_json" = "null" ] || [ -z "$beads_json" ]; then
            # Fallback: count manually from bd list
            p1=$(bd list --status=open --priority=1 2>/dev/null | grep -c "^[○◐●]" || echo 0)
            p2=$(bd list --status=open --priority=2 2>/dev/null | grep -c "^[○◐●]" || echo 0)
            p3=$(bd list --status=open --priority=3 2>/dev/null | grep -c "^[○◐●]" || echo 0)
            total=$((p1 + p2 + p3))
            beads_json=$(printf "{\"p1\":%d,\"p2\":%d,\"p3\":%d,\"total\":%d}" "$p1" "$p2" "$p3" "$total")
        fi

        # 4. Recent activity from town.log (last 10 lines)
        if [ -f /gt/town.log ]; then
            recent_json=$(tail -10 /gt/town.log | jq -Rs "split(\"\n\") | map(select(length > 0))")
        else
            recent_json="[]"
        fi

        # 5. Mayor status
        mayor_attached=false
        if tmux has-session -t hq-mayor 2>/dev/null; then
            mayor_attached=true
        fi
        mayor_last="null"
        if [ -f /gt/mayor/town.json ]; then
            mayor_last=$(date -r /gt/mayor/town.json -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null | jq -R . 2>/dev/null || echo "null")
        fi

        # 6. Daemon status
        daemon_running=false
        daemon_pid=null
        dpid=$(pgrep -f "gt daemon" 2>/dev/null | head -1 || true)
        if [ -n "$dpid" ]; then
            daemon_running=true
            daemon_pid=$dpid
        fi

        # Assemble unified JSON via jq
        jq -n \
            --argjson polecats "$polecats_json" \
            --argjson convoys "$convoys_json" \
            --argjson open_beads "$beads_json" \
            --argjson recent_activity "$recent_json" \
            --argjson mayor_attached "$mayor_attached" \
            --argjson mayor_last "$mayor_last" \
            --argjson daemon_running "$daemon_running" \
            --argjson daemon_pid "$daemon_pid" \
            "{
                polecats: \$polecats,
                convoys: \$convoys,
                open_beads: \$open_beads,
                recent_activity: \$recent_activity,
                mayor: { attached: \$mayor_attached, last_activity: \$mayor_last },
                daemon: { running: \$daemon_running, pid: \$daemon_pid }
            }"
    '
}

sync_to_instance() {
    local cname="$1"
    local inst="$2"

    # Sync formulas
    for f in "$SCRIPT_DIR/formulas"/*.formula.toml; do
        [ -f "$f" ] || continue
        docker cp "$f" "$cname:/gt/.beads/formulas/"
    done

    # Sync plugins (each plugin is a directory)
    for plugin_dir in "$SCRIPT_DIR/plugins"/*/; do
        [ -d "$plugin_dir" ] || continue
        local plugin_name
        plugin_name="$(basename "$plugin_dir")"
        docker exec "$cname" mkdir -p "/gt/plugins/$plugin_name" 2>/dev/null || true
        for f in "$plugin_dir"*; do
            [ -f "$f" ] || continue
            docker cp "$f" "$cname:/gt/plugins/$plugin_name/"
        done
    done
}

cmd_formulas() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list|ls)
            echo "Custom formulas in $SCRIPT_DIR/formulas/:"
            echo ""
            for f in "$SCRIPT_DIR/formulas"/*.formula.toml; do
                [ -f "$f" ] || { echo "  (none)"; break; }
                local name
                name="$(basename "$f" .formula.toml)"
                local desc
                desc=$(grep -m1 '^formula' "$f" 2>/dev/null | cut -d'"' -f2)
                printf "  %-30s %s\n" "$name" "$desc"
            done
            echo ""
            echo "Custom plugins in $SCRIPT_DIR/plugins/:"
            echo ""
            for d in "$SCRIPT_DIR/plugins"/*/; do
                [ -d "$d" ] || { echo "  (none)"; break; }
                local pname
                pname="$(basename "$d")"
                local pdesc
                pdesc=$(grep -m1 '^description' "$d/plugin.md" 2>/dev/null | cut -d'"' -f2)
                printf "  %-30s %s\n" "$pname" "$pdesc"
            done
            ;;
        sync)
            local instance="$1"
            if [[ -z "$instance" ]]; then
                echo "Usage: gt-docker formulas sync <instance|--all>" >&2
                exit 1
            fi
            if [[ "$instance" == "--all" ]]; then
                echo "Syncing formulas and plugins to all running instances..."
                for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                    local inst="${cname#gastown-}"
                    echo "  → $inst"
                    sync_to_instance "$cname" "$inst"
                done
                echo "Done."
            else
                local cname
                cname="$(container_name "$instance")"
                require_running "$instance"
                echo "Syncing formulas and plugins to instance '$instance'..."
                sync_to_instance "$cname" "$instance"
                echo "  Formulas:"
                for f in "$SCRIPT_DIR/formulas"/*.formula.toml; do
                    [ -f "$f" ] || continue
                    echo "    → $(basename "$f")"
                done
                echo "  Plugins:"
                for d in "$SCRIPT_DIR/plugins"/*/; do
                    [ -d "$d" ] || continue
                    echo "    → $(basename "$d")/"
                done
                echo "Done."
            fi
            ;;
        add)
            local formula_path="$1"
            if [[ -z "$formula_path" || ! -f "$formula_path" ]]; then
                echo "Usage: gt-docker formulas add <path-to-formula.toml>" >&2
                exit 1
            fi
            cp "$formula_path" "$SCRIPT_DIR/formulas/"
            echo "Added $(basename "$formula_path") to custom formulas."
            echo "Run 'gt-docker formulas sync --all' to push to running instances."
            ;;
        *)
            cat <<'FEOF'
gt-docker formulas — manage custom formulas and plugins

Usage:
  gt-docker formulas list                List custom formulas and plugins
  gt-docker formulas add <file>          Add a formula to the collection
  gt-docker formulas sync <instance>     Push formulas + plugins to a running instance
  gt-docker formulas sync --all          Push to all running instances
FEOF
            ;;
    esac
}

sync_settings_to_instance() {
    local cname="$1"
    local inst="$2"

    # Copy settings files into the container
    docker cp "$SCRIPT_DIR/settings/disabled-plugins.json" "$cname:/tmp/disabled-plugins.json"
    docker cp "$SCRIPT_DIR/settings/apply-settings.sh" "$cname:/tmp/apply-settings.sh"
    docker exec "$cname" chmod +x /tmp/apply-settings.sh

    # Create a temp settings dir and run the apply script
    docker exec "$cname" mkdir -p /tmp/custom-settings
    docker exec "$cname" cp /tmp/disabled-plugins.json /tmp/custom-settings/
    docker exec "$cname" /tmp/apply-settings.sh /tmp/custom-settings /gt
}

cmd_settings() {
    local subcmd="${1:-show}"
    shift 2>/dev/null || true

    case "$subcmd" in
        show)
            echo "Disabled plugins (settings/disabled-plugins.json):"
            echo ""
            python3 -c "
import json
with open('$SCRIPT_DIR/settings/disabled-plugins.json') as f:
    data = json.load(f)
for k, v in data.items():
    if not k.startswith('_'):
        print(f'  {k}: {v}')
"
            ;;
        sync)
            local instance="${1:-}"
            if [[ -z "$instance" ]]; then
                echo "Usage: gt-docker settings sync <instance|--all>" >&2
                exit 1
            fi
            if [[ "$instance" == "--all" ]]; then
                echo "Syncing plugin settings to all running instances..."
                for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                    local inst="${cname#gastown-}"
                    echo "  → $inst"
                    sync_settings_to_instance "$cname" "$inst"
                done
                echo "Done."
            else
                local cname
                cname="$(container_name "$instance")"
                require_running "$instance"
                echo "Syncing plugin settings to instance '$instance'..."
                sync_settings_to_instance "$cname" "$instance"
                echo "Done."
            fi
            ;;
        *)
            cat <<'SEOF'
gt-docker settings — manage Claude Code plugin settings

Usage:
  gt-docker settings show               Show disabled plugins list
  gt-docker settings sync <instance>     Push plugin settings to a running instance
  gt-docker settings sync --all          Push to all running instances

Edit settings/disabled-plugins.json to control which plugins are disabled.
SEOF
            ;;
    esac
}

cmd_tier() {
    local target="${1:-}"
    local new_tier="${2:-}"

    if [[ -z "$target" ]]; then
        cat <<'TEOF'
gt-docker tier — manage cost tiers for Gas Town instances

Usage:
  gt-docker tier <instance>          Show current cost tier
  gt-docker tier <instance> <tier>   Set cost tier (standard/economy/budget)
  gt-docker tier --all               Show tier for all running instances
  gt-docker tier --all <tier>        Set tier for all running instances

Tiers:
  standard   All roles use Opus (highest quality, highest cost)
  economy    Patrol roles use Sonnet/Haiku, workers use Opus
  budget     Patrol roles use Haiku, workers use Sonnet
TEOF
        return
    fi

    if [[ "$target" == "--all" ]]; then
        if [[ -z "$new_tier" ]]; then
            echo "Cost tiers for running instances:"
            echo ""
            for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                local inst="${cname#gastown-}"
                local tier
                tier=$(docker exec "$cname" sh -c 'echo ${GT_COST_TIER:-standard}' 2>/dev/null)
                printf "  %-20s %s\n" "$inst" "$tier"
            done
        else
            echo "Setting cost tier to '$new_tier' for all running instances..."
            for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                local inst="${cname#gastown-}"
                echo "  → $inst: restarting with --cost-tier $new_tier"
                docker exec "$cname" /app/gastown/gt stop 2>/dev/null || true
                docker exec -e "GT_COST_TIER=$new_tier" "$cname" sh -c \
                    '/app/gastown/gt up --cost-tier '"$new_tier"' 2>&1 || echo "Warning: gt up failed"'
            done
            echo "Done."
        fi
    else
        local cname
        cname="$(container_name "$target")"
        require_running "$target"

        if [[ -z "$new_tier" ]]; then
            local tier
            tier=$(docker exec "$cname" sh -c 'echo ${GT_COST_TIER:-standard}' 2>/dev/null)
            echo "Instance '$target' cost tier: $tier"
        else
            echo "Setting cost tier to '$new_tier' for instance '$target'..."
            docker exec "$cname" /app/gastown/gt stop 2>/dev/null || true
            docker exec -e "GT_COST_TIER=$new_tier" "$cname" sh -c \
                '/app/gastown/gt up --cost-tier '"$new_tier"' 2>&1 || echo "Warning: gt up failed"'
            echo "Done."
        fi
    fi
}

cmd_costs() {
    local subcmd="${1:-}"

    # Handle "costs export <instance>" subcommand
    if [[ "$subcmd" == "export" ]]; then
        shift
        local instance="${1:-}"
        shift 2>/dev/null || true
        if [[ -z "$instance" ]]; then
            echo "Usage: gt-docker costs export <instance> [output-dir]" >&2
            exit 1
        fi
        local cname
        cname="$(container_name "$instance")"
        require_running "$instance"

        local outdir="${1:-$SCRIPT_DIR/costs}"
        mkdir -p "$outdir"
        local datestamp
        datestamp="$(date +%Y-%m-%d)"
        local outfile="$outdir/${instance}-costs-${datestamp}.jsonl"

        echo "Exporting cost ledger from instance '$instance'..."
        docker cp "$cname:/home/agent/.gt/costs.jsonl" "$outfile" 2>/dev/null
        if [[ $? -eq 0 && -f "$outfile" ]]; then
            local lines
            lines=$(wc -l < "$outfile" | tr -d ' ')
            echo "Exported $lines entries to $outfile"
        else
            echo "No cost data found (costs.jsonl does not exist yet)." >&2
            rm -f "$outfile"
        fi
        return
    fi

    # Pass everything through to gt costs inside the container
    local instance="$subcmd"
    if [[ -z "$instance" ]]; then
        echo "Usage: gt-docker costs <instance> [gt-costs-flags...]" >&2
        echo "       gt-docker costs export <instance> [output-dir]" >&2
        exit 1
    fi
    shift
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    docker exec --user agent "$cname" gt costs "$@"
}

cmd_tokens() {
    local instance="${1:-}"
    if [[ -z "$instance" ]]; then
        echo "Usage: gt-docker tokens <instance> [--by-role]" >&2
        exit 1
    fi
    shift
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    docker exec --user agent "$cname" node /app/scripts/token-usage.js "$@"
}

# --- main ---

[[ $# -lt 1 ]] && usage

cmd="$1"
shift

case "$cmd" in
    up|start)
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
            cat <<'UPEOF'
gt-docker up — create and start an instance

Usage:
  gt-docker up <instance>

Creates a new Gas Town Docker instance with the specified name.
The instance will start all services (Dolt, Daemon, Deacon, Mayor, Dashboard, Terminal).

Environment variables:
  GT_COST_TIER   Cost tier: standard/economy/budget (default: budget)
  DASHBOARD_PORT Host port for dashboard (default: auto-assigned from ports.conf)
  TERMINAL_PORT  Host port for terminal (default: auto-assigned from ports.conf)
  WEB_PORTS      Host-to-container web port range (default: 3000-3050:3000-3050)
  GIT_USER       Git user.name  (default: TestUser)
  GIT_EMAIL      Git user.email (default: test@example.com)

Examples:
  gt-docker up alpha
  GT_COST_TIER=standard gt-docker up bravo
UPEOF
            exit 0
        fi
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker up <instance>" >&2; exit 1; }
        cmd_up "$1"
        ;;
    down|stop)
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
            cat <<'DOWNEOF'
gt-docker down — gracefully stop an instance

Usage:
  gt-docker down <instance>

Performs a graceful shutdown before stopping the container:
  1. Saves Mayor context via handoff mail (restored on next gt-docker up)
  2. Records costs for all active sessions to the cost ledger
  3. Stops all Gas Town services cleanly (agents, dolt, daemon)
  4. Stops and removes the container

Volumes are preserved, so you can restart the instance later with all data intact.

To completely remove an instance including volumes, use:
  gt-docker destroy <instance>

Examples:
  gt-docker down alpha
DOWNEOF
            exit 0
        fi
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker down <instance>" >&2; exit 1; }
        cmd_down "$1"
        ;;
    destroy|rm)
        if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
            cat <<'DESTROYEOF'
gt-docker destroy — stop, remove, and delete volumes

Usage:
  gt-docker destroy <instance>

Completely removes the specified instance, including:
  - The container
  - All associated volumes
  - All data (Git repositories, databases, logs, etc.)

This action cannot be undone. Use with caution.


#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks to find the real script directory
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
PORTS_FILE="$SCRIPT_DIR/ports.conf"

# macOS Docker Desktop puts binaries here
if [[ -d /Applications/Docker.app/Contents/Resources/bin ]]; then
    export PATH="/Applications/Docker.app/Contents/Resources/bin:$PATH"
fi

# Look up a static port for an instance from ports.conf
# Usage: get_port <instance> [dashboard|terminal]
get_port() {
    local instance="$1"
    local type="${2:-dashboard}"
    if [[ -f "$PORTS_FILE" ]]; then
        local port
        port=$(grep -E "^${instance}\.${type}=" "$PORTS_FILE" 2>/dev/null | cut -d= -f2 | tr -d ' ')
        if [[ -n "$port" ]]; then
            echo "$port"
            return
        fi
    fi
    echo "0"  # auto-assign
}

usage() {
    cat <<'EOF'
gt-docker — manage isolated Gas Town Docker instances

Usage:
  gt-docker up <instance>            Create and start an instance
  gt-docker down <instance>          Stop and remove an instance (keeps volumes)
  gt-docker destroy <instance>       Stop, remove, AND delete volumes
  gt-docker mayor <instance>         Attach to the Mayor tmux session
  gt-docker shell <instance>         Open a shell in the container
  gt-docker exec <instance> <cmd..>  Run a command in the container
  gt-docker list                     List running gastown containers
  gt-docker logs <instance>          Tail container logs

  gt-docker formulas list            List custom formulas
  gt-docker formulas add <file>      Add a formula to the collection
  gt-docker formulas sync <instance> Push formulas to a running instance
  gt-docker formulas sync --all      Push to all running instances

  gt-docker settings sync <instance> Push plugin settings to a running instance
  gt-docker settings sync --all      Push to all running instances
  gt-docker settings show            Show disabled plugins list

  gt-docker tier <instance> [tier]   Get or set cost tier (standard/economy/budget)
  gt-docker tier --all [tier]        Get or set tier for all running instances

  gt-docker memory export <instance> <file>    Export memories to a tar.gz file
  gt-docker memory import <instance> <file>    Import memories from a tar.gz file
  gt-docker memory sync <source> <dest>        Sync memories between instances
  gt-docker memory list <instance>             List memories in an instance

Environment:
  GIT_USER       Git user.name  (default: TestUser)
  GIT_EMAIL      Git user.email (default: test@example.com)
  GT_COST_TIER   Cost tier for new instances (default: budget)
  DASHBOARD_PORT Host port for dashboard (default: auto-assigned)
  WEB_PORTS      Host-to-container web port range (default: 3000-3050:3000-3050)

Cost Tiers:
  standard       All roles use Opus (highest quality, highest cost)
  economy        Patrol roles use Sonnet/Haiku, workers use Opus
  budget         Patrol roles use Haiku, workers use Sonnet (default)

Examples:
  gt-docker up alpha
  gt-docker up bravo
  gt-docker mayor alpha              # attach to alpha's Mayor
  gt-docker exec bravo gt agents     # check agents in bravo
  gt-docker list                     # see all running instances
  gt-docker tier alpha budget        # switch alpha to budget tier
  gt-docker settings sync --all      # push plugin settings everywhere
  gt-docker destroy alpha            # tear down alpha completely
EOF
    exit 1
}

container_name() {
    echo "gastown-$1"
}

compose_env() {
    local instance="$1"
    export GT_INSTANCE="$instance"
    export COMPOSE_PROJECT_NAME="gt-$instance"
}

require_running() {
    local cname
    cname="$(container_name "$1")"
    if ! docker inspect --format='{{.State.Running}}' "$cname" 2>/dev/null | grep -q true; then
        echo "Error: instance '$1' is not running (container: $cname)" >&2
        echo "Start it with: gt-docker up $1" >&2
        exit 1
    fi
}

cmd_up() {
    local instance="$1"
    compose_env "$instance"
    export DASHBOARD_PORT="${DASHBOARD_PORT:-$(get_port "$instance" dashboard)}"
    export TERMINAL_PORT="${TERMINAL_PORT:-$(get_port "$instance" terminal)}"
    local webstart
    webstart="$(get_port "$instance" webstart)"
    if [[ "$webstart" != "0" ]]; then
        local webend=$((webstart + 50))
        export WEB_PORTS="${WEB_PORTS:-${webstart}-${webend}:3000-3050}"
    else
        export WEB_PORTS="${WEB_PORTS:-3000-3050:3000-3050}"
    fi
    export GT_COST_TIER="${GT_COST_TIER:-budget}"
    echo "Starting gastown instance '$instance' (cost tier: $GT_COST_TIER)..."
    docker compose -f "$COMPOSE_FILE" up -d --build
    echo ""
    echo "Instance '$instance' is running."
    echo "  Container:  $(container_name "$instance")"
    echo "  Cost tier:  $GT_COST_TIER"
    if [[ "$DASHBOARD_PORT" != "0" ]]; then
        echo "  Dashboard:  http://${instance}.town"
    fi
    if [[ "$TERMINAL_PORT" != "0" ]]; then
        echo "  Terminal:   http://terminal.${instance}.town"
    fi
    echo "  Web ports:  ${WEB_PORTS%:*} → container 3000-3050"
    echo ""
    echo "Services (Dolt, Daemon, Deacon, Mayor, Dashboard, Terminal)"
    echo "start automatically inside the container."
    echo ""
    echo "First time? Authenticate Claude:"
    echo "  gt-docker shell $instance"
    echo "  claude login"
    echo ""
    echo "Attach to Mayor:"
    echo "  gt-docker mayor $instance"
}

cmd_down() {
    local instance="$1"
    compose_env "$instance"
    echo "Stopping instance '$instance'..."
    docker compose -f "$COMPOSE_FILE" down
}

cmd_destroy() {
    local instance="$1"
    compose_env "$instance"
    echo "Destroying instance '$instance' (including volumes)..."
    docker compose -f "$COMPOSE_FILE" down -v
}

cmd_mayor() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"

    # Check if the mayor tmux session exists
    if docker exec --user agent "$cname" tmux has-session -t hq-mayor 2>/dev/null; then
        echo "Attaching to Mayor in instance '$instance'..."
        docker exec -it --user agent "$cname" tmux attach-session -t hq-mayor
    else
        # No mayor session yet — start one via gt mayor attach
        echo "No Mayor session found in '$instance'. Starting one..."
        docker exec -it --user agent "$cname" /app/gastown/gt mayor attach
    fi
}

cmd_shell() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    docker exec -it --user agent "$cname" zsh
}

cmd_exec_cmd() {
    local instance="$1"
    shift
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    if [[ -t 0 ]]; then
        docker exec -it --user agent "$cname" "$@"
    else
        docker exec --user agent "$cname" "$@"
    fi
}

cmd_list() {
    echo "Running gastown instances:"
    echo ""
    docker ps --filter "name=gastown-" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
}

cmd_logs() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"
    docker logs -f "$cname"
}

sync_to_instance() {
    local cname="$1"
    local inst="$2"

    # Sync formulas
    for f in "$SCRIPT_DIR/formulas"/*.formula.toml; do
        [ -f "$f" ] || continue
        docker cp "$f" "$cname:/gt/.beads/formulas/"
    done

    # Sync plugins (each plugin is a directory)
    for plugin_dir in "$SCRIPT_DIR/plugins"/*/; do
        [ -d "$plugin_dir" ] || continue
        local plugin_name
        plugin_name="$(basename "$plugin_dir")"
        docker exec "$cname" mkdir -p "/gt/plugins/$plugin_name" 2>/dev/null || true
        for f in "$plugin_dir"*; do
            [ -f "$f" ] || continue
            docker cp "$f" "$cname:/gt/plugins/$plugin_name/"
        done
    done
}

cmd_formulas() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list|ls)
            echo "Custom formulas in $SCRIPT_DIR/formulas/:"
            echo ""
            for f in "$SCRIPT_DIR/formulas"/*.formula.toml; do
                [ -f "$f" ] || { echo "  (none)"; break; }
                local name
                name="$(basename "$f" .formula.toml)"
                local desc
                desc=$(grep -m1 '^formula' "$f" 2>/dev/null | cut -d'"' -f2)
                printf "  %-30s %s\n" "$name" "$desc"
            done
            echo ""
            echo "Custom plugins in $SCRIPT_DIR/plugins/:"
            echo ""
            for d in "$SCRIPT_DIR/plugins"/*/; do
                [ -d "$d" ] || { echo "  (none)"; break; }
                local pname
                pname="$(basename "$d")"
                local pdesc
                pdesc=$(grep -m1 '^description' "$d/plugin.md" 2>/dev/null | cut -d'"' -f2)
                printf "  %-30s %s\n" "$pname" "$pdesc"
            done
            ;;
        sync)
            local instance="$1"
            if [[ -z "$instance" ]]; then
                echo "Usage: gt-docker formulas sync <instance|--all>" >&2
                exit 1
            fi
            if [[ "$instance" == "--all" ]]; then
                echo "Syncing formulas and plugins to all running instances..."
                for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                    local inst="${cname#gastown-}"
                    echo "  → $inst"
                    sync_to_instance "$cname" "$inst"
                done
                echo "Done."
            else
                local cname
                cname="$(container_name "$instance")"
                require_running "$instance"
                echo "Syncing formulas and plugins to instance '$instance'..."
                sync_to_instance "$cname" "$instance"
                echo "  Formulas:"
                for f in "$SCRIPT_DIR/formulas"/*.formula.toml; do
                    [ -f "$f" ] || continue
                    echo "    → $(basename "$f")"
                done
                echo "  Plugins:"
                for d in "$SCRIPT_DIR/plugins"/*/; do
                    [ -d "$d" ] || continue
                    echo "    → $(basename "$d")/"
                done
                echo "Done."
            fi
            ;;
        add)
            local formula_path="$1"
            if [[ -z "$formula_path" || ! -f "$formula_path" ]]; then
                echo "Usage: gt-docker formulas add <path-to-formula.toml>" >&2
                exit 1
            fi
            cp "$formula_path" "$SCRIPT_DIR/formulas/"
            echo "Added $(basename "$formula_path") to custom formulas."
            echo "Run 'gt-docker formulas sync --all' to push to running instances."
            ;;
        *)
            cat <<'FEOF'
gt-docker formulas — manage custom formulas and plugins

Usage:
  gt-docker formulas list                List custom formulas and plugins
  gt-docker formulas add <file>          Add a formula to the collection
  gt-docker formulas sync <instance>     Push formulas + plugins to a running instance
  gt-docker formulas sync --all          Push to all running instances
FEOF
            ;;
    esac
}

sync_settings_to_instance() {
    local cname="$1"
    local inst="$2"

    # Copy settings files into the container
    docker cp "$SCRIPT_DIR/settings/disabled-plugins.json" "$cname:/tmp/disabled-plugins.json"
    docker cp "$SCRIPT_DIR/settings/apply-settings.sh" "$cname:/tmp/apply-settings.sh"
    docker exec "$cname" chmod +x /tmp/apply-settings.sh

    # Create a temp settings dir and run the apply script
    docker exec "$cname" mkdir -p /tmp/custom-settings
    docker exec "$cname" cp /tmp/disabled-plugins.json /tmp/custom-settings/
    docker exec "$cname" /tmp/apply-settings.sh /tmp/custom-settings /gt
}

cmd_settings() {
    local subcmd="${1:-show}"
    shift 2>/dev/null || true

    case "$subcmd" in
        show)
            echo "Disabled plugins (settings/disabled-plugins.json):"
            echo ""
            python3 -c "
import json
with open('$SCRIPT_DIR/settings/disabled-plugins.json') as f:
    data = json.load(f)
for k, v in data.items():
    if not k.startswith('_'):
        print(f'  {k}: {v}')
"
            ;;
        sync)
            local instance="${1:-}"
            if [[ -z "$instance" ]]; then
                echo "Usage: gt-docker settings sync <instance|--all>" >&2
                exit 1
            fi
            if [[ "$instance" == "--all" ]]; then
                echo "Syncing plugin settings to all running instances..."
                for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                    local inst="${cname#gastown-}"
                    echo "  → $inst"
                    sync_settings_to_instance "$cname" "$inst"
                done
                echo "Done."
            else
                local cname
                cname="$(container_name "$instance")"
                require_running "$instance"
                echo "Syncing plugin settings to instance '$instance'..."
                sync_settings_to_instance "$cname" "$instance"
                echo "Done."
            fi
            ;;
        *)
            cat <<'SEOF'
gt-docker settings — manage Claude Code plugin settings

Usage:
  gt-docker settings show               Show disabled plugins list
  gt-docker settings sync <instance>     Push plugin settings to a running instance
  gt-docker settings sync --all          Push to all running instances

Edit settings/disabled-plugins.json to control which plugins are disabled.
SEOF
            ;;
    esac
}

cmd_tier() {
    local target="${1:-}"
    local new_tier="${2:-}"

    if [[ -z "$target" ]]; then
        cat <<'TEOF'
gt-docker tier — manage cost tiers for Gas Town instances

Usage:
  gt-docker tier <instance>          Show current cost tier
  gt-docker tier <instance> <tier>   Set cost tier (standard/economy/budget)
  gt-docker tier --all               Show tier for all running instances
  gt-docker tier --all <tier>        Set tier for all running instances

Tiers:
  standard   All roles use Opus (highest quality, highest cost)
  economy    Patrol roles use Sonnet/Haiku, workers use Opus
  budget     Patrol roles use Haiku, workers use Sonnet
TEOF
        return
    fi

    if [[ "$target" == "--all" ]]; then
        if [[ -z "$new_tier" ]]; then
            echo "Cost tiers for running instances:"
            echo ""
            for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                local inst="${cname#gastown-}"
                local tier
                tier=$(docker exec "$cname" sh -c 'echo ${GT_COST_TIER:-standard}' 2>/dev/null)
                printf "  %-20s %s\n" "$inst" "$tier"
            done
        else
            echo "Setting cost tier to '$new_tier' for all running instances..."
            for cname in $(docker ps --filter "name=gastown-" --format "{{.Names}}"); do
                local inst="${cname#gastown-}"
                echo "  → $inst: restarting with --cost-tier $new_tier"
                docker exec "$cname" /app/gastown/gt stop 2>/dev/null || true
                docker exec -e "GT_COST_TIER=$new_tier" "$cname" sh -c \
                    '/app/gastown/gt up --cost-tier '"$new_tier"' 2>&1 || echo "Warning: gt up failed"'
            done
            echo "Done."
        fi
    else
        local cname
        cname="$(container_name "$target")"
        require_running "$target"

        if [[ -z "$new_tier" ]]; then
            local tier
            tier=$(docker exec "$cname" sh -c 'echo ${GT_COST_TIER:-standard}' 2>/dev/null)
            echo "Instance '$target' cost tier: $tier"
        else
            echo "Setting cost tier to '$new_tier' for instance '$target'..."
            docker exec "$cname" /app/gastown/gt stop 2>/dev/null || true
            docker exec -e "GT_COST_TIER=$new_tier" "$cname" sh -c \
                '/app/gastown/gt up --cost-tier '"$new_tier"' 2>&1 || echo "Warning: gt up failed"'
            echo "Done."
        fi
    fi
}

cmd_memory() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "$subcmd" in
        export)
            local instance="${1:-}"
            local output_file="${2:-}"
            if [[ -z "$instance" || -z "$output_file" ]]; then
                echo "Usage: gt-docker memory export <instance> <output-file>" >&2
                exit 1
            fi
            cmd_memory_export "$instance" "$output_file"
            ;;
        import)
            local instance="${1:-}"
            local input_file="${2:-}"
            if [[ -z "$instance" || -z "$input_file" ]]; then
                echo "Usage: gt-docker memory import <instance> <input-file>" >&2
                exit 1
            fi
            cmd_memory_import "$instance" "$input_file"
            ;;
        sync)
            local source="${1:-}"
            local dest="${2:-}"
            if [[ -z "$source" || -z "$dest" ]]; then
                echo "Usage: gt-docker memory sync <source-instance> <dest-instance>" >&2
                exit 1
            fi
            cmd_memory_sync "$source" "$dest"
            ;;
        list|ls)
            local instance="${1:-}"
            if [[ -z "$instance" ]]; then
                echo "Usage: gt-docker memory list <instance>" >&2
                exit 1
            fi
            cmd_memory_list "$instance"
            ;;
        *)
            cat <<'MEOF'
gt-docker memory — manage Gas Town memories across instances

Usage:
  gt-docker memory export <instance> <file>    Export memories to tar.gz file
  gt-docker memory import <instance> <file>    Import memories from tar.gz file
  gt-docker memory sync <source> <dest>        Sync memories between instances
  gt-docker memory list <instance>             List memories in an instance

What gets synced:
  - bd kv store (Gas Town agent memories with memory.* prefix)
  - Claude Code auto-memory files (~/.claude/projects/*/memory/)
  - Brainstorm artifacts (/gt/.brainstorms/)

Examples:
  gt-docker memory export alpha memories-alpha.tar.gz
  gt-docker memory import bravo memories-alpha.tar.gz
  gt-docker memory sync alpha bravo              # alpha → bravo
  gt-docker memory list alpha
MEOF
            ;;
    esac
}

cmd_memory_export() {
    local instance="$1"
    local output_file="$2"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"

    echo "Exporting memories from instance '$instance'..."

    # Create temp directory for export
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    # Export bd kv store
    echo "  → Exporting bd kv store..."
    docker exec "$cname" bd kv list --json > "$tmpdir/bd-kv.json" 2>/dev/null || echo "{}" > "$tmpdir/bd-kv.json"

    # Export Claude Code memory
    echo "  → Exporting Claude Code memory..."
    mkdir -p "$tmpdir/claude-memory"
    docker exec "$cname" sh -c 'if [ -d ~/.claude/projects ]; then tar czf - -C ~/.claude/projects . 2>/dev/null; fi' | tar xzf - -C "$tmpdir/claude-memory" 2>/dev/null || true

    # Export brainstorm artifacts
    echo "  → Exporting brainstorm artifacts..."
    mkdir -p "$tmpdir/brainstorms"
    docker exec "$cname" sh -c 'if [ -d /gt/.brainstorms ]; then tar czf - -C /gt/.brainstorms . 2>/dev/null; fi' | tar xzf - -C "$tmpdir/brainstorms" 2>/dev/null || true

    # Create final archive
    echo "  → Creating archive..."
    tar czf "$output_file" -C "$tmpdir" . 2>/dev/null

    echo "Exported memories to: $output_file"
    echo ""
    echo "Archive contents:"
    tar tzf "$output_file" | head -20
    local total_files
    total_files=$(tar tzf "$output_file" | wc -l)
    if [[ $total_files -gt 20 ]]; then
        echo "... and $((total_files - 20)) more files"
    fi
}

cmd_memory_import() {
    local instance="$1"
    local input_file="$2"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"

    if [[ ! -f "$input_file" ]]; then
        echo "Error: input file '$input_file' not found" >&2
        exit 1
    fi

    echo "Importing memories into instance '$instance'..."

    # Create temp directory for import
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" EXIT

    # Extract archive
    echo "  → Extracting archive..."
    tar xzf "$input_file" -C "$tmpdir"

    # Import bd kv store with conflict handling
    if [[ -f "$tmpdir/bd-kv.json" ]]; then
        echo "  → Importing bd kv store..."

        # Get existing keys
        local existing_kv
        existing_kv=$(docker exec "$cname" bd kv list --json 2>/dev/null || echo "{}")

        # Parse and import each key-value pair
        python3 <<PYEOF
import json
import subprocess
import sys

# Load source and existing kv data
with open("$tmpdir/bd-kv.json") as f:
    source_kv = json.load(f)

existing_kv = json.loads('''$existing_kv''')

conflicts = []
imports = []

for key, value in source_kv.items():
    if key in existing_kv and existing_kv[key] != value:
        conflicts.append((key, existing_kv[key], value))
    else:
        imports.append((key, value))

# Import non-conflicting keys
for key, value in imports:
    subprocess.run(["docker", "exec", "$cname", "bd", "kv", "set", key, value], check=False)

# Handle conflicts
if conflicts:
    print("\n⚠️  Conflicts detected:")
    print("")
    for key, existing_val, new_val in conflicts:
        print(f"  Key: {key}")
        print(f"    Existing: {existing_val[:100]}...")
        print(f"    Import:   {new_val[:100]}...")
        print("")
        while True:
            choice = input("  Keep [e]xisting, import [n]ew, or [s]kip? ").strip().lower()
            if choice in ['e', 'n', 's']:
                break
        if choice == 'n':
            subprocess.run(["docker", "exec", "$cname", "bd", "kv", "set", key, new_val], check=False)
            print(f"  ✓ Imported {key}")
        elif choice == 'e':
            print(f"  ✓ Kept existing {key}")
        else:
            print(f"  ⊘ Skipped {key}")
        print("")

print(f"Imported {len(imports)} keys, handled {len(conflicts)} conflicts")
PYEOF
    fi

    # Import Claude Code memory
    if [[ -d "$tmpdir/claude-memory" && -n "$(ls -A "$tmpdir/claude-memory" 2>/dev/null)" ]]; then
        echo "  → Importing Claude Code memory..."
        tar czf - -C "$tmpdir/claude-memory" . | docker exec -i "$cname" sh -c 'mkdir -p ~/.claude/projects && tar xzf - -C ~/.claude/projects'
    fi

    # Import brainstorm artifacts
    if [[ -d "$tmpdir/brainstorms" && -n "$(ls -A "$tmpdir/brainstorms" 2>/dev/null)" ]]; then
        echo "  → Importing brainstorm artifacts..."
        tar czf - -C "$tmpdir/brainstorms" . | docker exec -i "$cname" sh -c 'mkdir -p /gt/.brainstorms && tar xzf - -C /gt/.brainstorms'
    fi

    echo "✓ Import complete"
}

cmd_memory_sync() {
    local source="$1"
    local dest="$2"

    echo "Syncing memories from '$source' → '$dest'..."

    # Create temp file for export
    local tmpfile
    tmpfile=$(mktemp --suffix=.tar.gz)
    trap "rm -f '$tmpfile'" EXIT

    # Export from source
    cmd_memory_export "$source" "$tmpfile"

    echo ""

    # Import to destination
    cmd_memory_import "$dest" "$tmpfile"

    echo ""
    echo "✓ Sync complete: '$source' → '$dest'"
}

cmd_memory_list() {
    local instance="$1"
    local cname
    cname="$(container_name "$instance")"
    require_running "$instance"

    echo "Memories in instance '$instance':"
    echo ""

    # List bd kv store
    echo "bd kv store:"
    local kv_json
    kv_json=$(docker exec "$cname" bd kv list --json 2>/dev/null || echo "{}")
    if [[ "$kv_json" == "{}" ]]; then
        echo "  (empty)"
    else
        echo "$kv_json" | python3 -c "
import json, sys
kv = json.load(sys.stdin)
for key, value in sorted(kv.items()):
    print(f'  {key}: {value[:80]}...' if len(value) > 80 else f'  {key}: {value}')
"
    fi

    echo ""

    # List Claude Code memory
    echo "Claude Code memory:"
    docker exec "$cname" sh -c 'if [ -d ~/.claude/projects ]; then find ~/.claude/projects -name "*.md" -type f 2>/dev/null | sed "s|^/home/agent/||" | sed "s/^/  /"; fi' 2>/dev/null || echo "  (none found)"

    echo ""

    # List brainstorm artifacts
    echo "Brainstorm artifacts:"
    docker exec "$cname" sh -c 'if [ -d /gt/.brainstorms ]; then ls -1 /gt/.brainstorms 2>/dev/null | sed "s/^/  /"; fi' 2>/dev/null || echo "  (none found)"
}

# --- main ---

[[ $# -lt 1 ]] && usage

cmd="$1"
shift

case "$cmd" in
    up|start)
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker up <instance>" >&2; exit 1; }
        cmd_up "$1"
        ;;
    down|stop)
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker down <instance>" >&2; exit 1; }
        cmd_down "$1"
        ;;
    destroy|rm)
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker destroy <instance>" >&2; exit 1; }
        cmd_destroy "$1"
        ;;
    mayor|attach)
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker mayor <instance>" >&2; exit 1; }
        cmd_mayor "$1"
        ;;
    shell|sh)
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker shell <instance>" >&2; exit 1; }
        cmd_shell "$1"
        ;;
    exec)
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker exec <instance> <cmd..>" >&2; exit 1; }
        cmd_exec_cmd "$@"
        ;;
    list|ls|ps)
        cmd_list
        ;;
    logs)
        [[ $# -lt 1 ]] && { echo "Usage: gt-docker logs <instance>" >&2; exit 1; }
        cmd_logs "$1"
        ;;
    formulas|formula)
        cmd_formulas "$@"
        ;;
    settings)
        cmd_settings "$@"
        ;;
    tier|cost-tier)
        cmd_tier "$@"
        ;;
    memory)
        cmd_memory "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $cmd" >&2
        usage
        ;;
esac
